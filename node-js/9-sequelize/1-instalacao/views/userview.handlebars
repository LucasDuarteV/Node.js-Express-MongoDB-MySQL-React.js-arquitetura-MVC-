<h1>{{user.name}}</h1>

<div class="user-details">

  <p>
    <strong>Profissão:</strong> {{user.occupation}}
  </p>

  {{#if user.newsletter}}
    <p class="newsletter">
      Recebe promoções: Sim
    </p>
  {{else}}
    <p class="no-newsletter">
      Recebe promoções: Não
    </p>
  {{/if}}

</div>

<a class="back" href="/">
  Voltar
</a>