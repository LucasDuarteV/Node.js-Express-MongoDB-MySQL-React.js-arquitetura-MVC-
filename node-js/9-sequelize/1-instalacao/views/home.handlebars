<h1>Usuários Cadastrados</h1>

<div class="users-container">

  {{#each users}}

    <div class="user-card">

      <h2>{{this.name}}</h2>

      <p>
        <strong>Profissão:</strong> {{this.occupation}}
      </p>

      {{#if this.newsletter}}
        <p class="newsletter">
          Recebe promoções: Sim
        </p>
      {{else}}
        <p class="no-newsletter">
          Recebe promoções: Não
        </p>
      {{/if}}

      <div class="actions">
        <a href="/users/{{this.id}}">
          Ver detalhes
        </a>
      </div>

    </div>

  {{/each}}

</div>